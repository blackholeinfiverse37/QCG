# Copy this file to .env and adjust values as needed.
# All values shown are defaults.

# -- Quantum Producer ---------------------------------------------------------
QCG_SHOTS=1024
QCG_SEED=42
QCG_SUPPORTED_MODES=entangled,direct,superdense
QCG_MAX_MESSAGE_LENGTH=256

# -- Translation Layer --------------------------------------------------------
QCG_CONTRACT_VERSION=1.0.0
QCG_CONFIDENCE_THRESHOLD=0.70
QCG_CORRUPTION_THRESHOLD=0.40

# -- Gateway ------------------------------------------------------------------
QCG_RATE_LIMIT_PER_MINUTE=60

# -- Adapter / Execution Contract Layer ---------------------------------------
QCG_EXEC_CONTRACT_VERSION=2.0.0
QCG_MIN_CONTRACT_VERSION=2.0.0
QCG_ALLOWED_PRODUCERS=CLASSICAL,QUANTUM,HYBRID

# -- Governance ---------------------------------------------------------------
# true = strict mode (halt on any violation)
# false = permissive mode (log violations, continue)
QCG_GOVERNANCE_STRICT=true

# -- Replay Enforcer / Registry ---------------------------------------------
# TTL for replay cache entries (seconds)
QCG_REPLAY_TTL_SECONDS=300.0
# Path to the durable replay registry JSON file
QCG_REPLAY_REGISTRY_PATH=replay_registry.json
# Maximum sequence gap before a message is classified as FUTURE
QCG_MAX_SEQUENCE_GAP=1000

# -- Consensus ----------------------------------------------------------------
# BFT quorum threshold (fraction of nodes that must agree)
QCG_CONSENSUS_QUORUM_THRESHOLD=0.66

# -- Distributed Simulation ---------------------------------------------------
QCG_SIM_NODE_COUNT=3
QCG_SIM_PRODUCER_COUNT=2

# -- Live Ecosystem Integration -----------------------------------------------
QCG_KESHAV_API_URL=https://keshav-cia7.onrender.com
QCG_KESHAV_TIMEOUT_SECONDS=15
QCG_KESHAV_ENABLED=true

# -- Logging ------------------------------------------------------------------
# json (production) | text (development)
QCG_LOG_LEVEL=INFO
QCG_LOG_FORMAT=json
# Optional: write logs to a rotating file (leave blank for stdout only)
# QCG_LOG_FILE=logs/qcg.log
