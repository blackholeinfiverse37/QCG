            "operation_name": "verify_replay",
            "description": "Verify that a message has not been replayed (duplicate/stale detection) and assign a monotonic sequence number.",
            "input_contract": {
              "type": "object",
              "required": ["message_id", "issued_at"],
              "properties": {
