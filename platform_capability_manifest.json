      "manifest": {
        "manifest_id": "USF-MANIFEST-001",
        "supported_operations": [
          {
            "operation_name": "discover_solvers",
            "description": "Discover available solver capabilities matching query criteria including problem type, constraints, and resource requirements.",
            "input_contract": {
              "type": "object",
              "required": ["problem_type"],
              "properties": {
                "problem_type": {
                  "type": "string",
                  "enum": ["LP", "MILP", "QUBO", "TSP", "VRP", "CP", "NLP", "MINLP"]
                },
                "required_constraints": {
                  "type": "array",
                  "items": {"type": "string", "enum": ["LINEAR", "NONLINEAR", "QUADRATIC", "LOGICAL", "GLOBAL", "CARDINALITY"]}
                },
                "require_deterministic": {"type": "boolean"},
                "require_replay": {"type": "boolean"},
                "available_memory_mb": {"type": "integer"},
                "available_cores": {"type": "integer"},
                "max_variables": {"type": "integer"},
                "max_constraints": {"type": "integer"}
              }
            },
            "output_contract": {
              "type": "object",
              "properties": {
                "solvers": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "solver_id": {"type": "string"},
                      "solver_name": {"type": "string"},
                      "version": {"type": "string"},
                      "supported_problem_types": {"type": "array"},
                      "deterministic_capability": {"type": "boolean"}
                    }
                  }
                }
              }
            },
            "execution_modes": ["SYNCHRONOUS"],
            "idempotent": true
          },
          {
            "operation_name": "execute_optimization",
            "description": "Execute an optimization problem through the solver fabric. Automatically selects the best solver unless overridden. Produces replay-safe evidence.",
            "input_contract": {
              "type": "object",
              "required": ["problem_schema"],
              "properties": {
                "problem_schema": {
                  "type": "object",
                  "required": ["problem_type"],
                  "properties": {
                    "problem_type": {"type": "string"},
                    "required_constraints": {"type": "array"},
                    "require_deterministic": {"type": "boolean"}
                  }
                },
                "payload": {"type": "object"},
                "execution_constraints": {
                  "type": "object",
                  "properties": {
                    "max_time_ms": {"type": "integer"},
                    "max_memory_mb": {"type": "integer"}
                  }
                },
                "solver_override": {"type": "string"}
              }
            },
            "output_contract": {
              "type": "object",
              "properties": {
                "trace_id": {"type": "string"},
                "replay_id": {"type": "string"},
                "status": {"type": "string", "enum": ["COMPLETED", "FAILED"]},
                "provenance": {
                  "type": "object",
                  "properties": {
                    "timestamp_start_ms": {"type": "integer"},
                    "timestamp_end_ms": {"type": "integer"},
                    "execution_duration_ms": {"type": "integer"},
                    "fabric_version": {"type": "string"},
                    "solver_id": {"type": "string"},
                    "solver_version": {"type": "string"}
                  }
                },
                "deterministic_inputs": {"type": "object"},
                "result": {"type": "object"}
              }
            },
            "execution_modes": ["SYNCHRONOUS", "ASYNCHRONOUS"],
            "idempotent": false
          },
          {
            "operation_name": "get_solver_health",
            "description": "Query the health status of a registered solver.",
            "input_contract": {
              "type": "object",
              "required": ["solver_id"],
              "properties": {
                "solver_id": {"type": "string"}
              }
            },
            "output_contract": {
              "type": "object",
              "properties": {
                "solver_id": {"type": "string"},
                "health_status": {"type": "string", "enum": ["ENABLED", "DISABLED", "UNKNOWN"]}
              }
            },
            "execution_modes": ["SYNCHRONOUS"],
            "idempotent": true
          }
        ],
        "execution_modes": ["SYNCHRONOUS", "ASYNCHRONOUS"],
        "determinism_guarantees": {
          "deterministic_execution": true,
          "deterministic_selection": true,
          "deterministic_evidence": true,
          "note": "Given identical inputs and solver seed, results are identical. Selection ranking is deterministic."
        },
        "replay_guarantees": {
          "replay_safe": true,
          "replay_metadata_captured": true,
          "replay_fields": ["trace_id", "replay_id", "deterministic_inputs", "provenance"],
          "note": "Every execution produces a replay-safe evidence package containing all state necessary for exact reconstruction."
        },
        "trust_requirements": {
